# Test Environment Configuration
# Copy this file to .env.test for test configuration

# API Base URL
EAM_BASE_URL=http://localhost:4000

# Keycloak Configuration (if AUTH_DISABLED=false)
KEYCLOAK_SERVER_URL=
KEYCLOAK_REALM=myapp
KEYCLOAK_CLIENT_ID=tap-eam-8a473212f5e306df-b
KEYCLOAK_CLIENT_SECRET=uly9XIcpLbZr473m2fUX9dPLelrZKg6C

# Test User Credentials (Required for password grant)
# You need to create a test user in Keycloak or use existing credentials
TEST_USERNAME=your_test_username
TEST_PASSWORD=your_test_password

# Alternative: Use client credentials grant (if supported)
# Set to 'client_credentials' to skip user login
KEYCLOAK_GRANT_TYPE=password