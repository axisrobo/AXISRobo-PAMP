# Backend Environment Configuration
# Copy this file to .env for local development

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/axisarch
DB_SCHEMA=eam

# Server Configuration
PORT=4000
HOST=0.0.0.0

# Authentication Configuration
# SECURITY: Set AUTH_DISABLED=true ONLY for local development
AUTH_DISABLED=true
AUTH_DEV_USER=dev_admin
AUTH_DEV_ROLE=admin
# Auth mode: dev (fixed dev user), local (username/password + JWT), oidc (Keycloak SSO, EE only)
AUTH_MODE=dev
# JWT secret for local auth (production: use a strong random key)
JWT_SECRET_KEY=change-me-in-production

# Keycloak Configuration (used when AUTH_DISABLED=false)
KEYCLOAK_SERVER_URL=
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# EA agent configuration
EA_AGENT_LLM_BASE_URL=
EA_AGENT_LLM_API_KEY=
EA_AGENT_LLM_MODEL=
EA_AGENT_VISION_MODEL=

# S3 Configuration
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# Email Configuration
EMAIL_SERVICE_URL=
EMAIL_FROM=noreply@axisarch.local

# CMDB Configuration
CMDB_API_URL=
CMDB_API_TOKEN=

# Site URL
SITE_URL=http://localhost:3000
ENABLE_CMDB_SYNC=false
